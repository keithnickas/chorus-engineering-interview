{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "../../dist/out-tsc",
    "module": "node16",
    "types": ["node"],
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "moduleResolution": "node16",
    "ignoreDeprecations": "5.0"
  },
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts"],
  "include": ["src/**/*.ts"]
}
