{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@pokemon-user-backend/*": ["packages/pokemon-user-backend/src/*"],
      "@pokemon-user-backend-e2e/*": ["packages/pokemon-user-backend-e2e/src/*"]
    }
  },
  "exclude": ["node_modules", "tmp"],
}
